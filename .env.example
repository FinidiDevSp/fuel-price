# ─────────────────────────────────────────────
# Fuel Price - Variables de entorno
# Copia este archivo como .env y ajusta valores
# ─────────────────────────────────────────────

# Aplicación
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=fuel_user
DB_PASSWORD=fuel_password
DB_NAME=fuel_price

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Precioil API (fuente de datos)
PRECIOIL_API_URL=
PRECIOIL_API_KEY=
